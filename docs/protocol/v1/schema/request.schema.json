{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openjax.dev/schemas/protocol/v1/request.schema.json",
  "title": "OpenJax Protocol v1 Request",
  "type": "object",
  "required": [
    "protocol_version",
    "kind",
    "request_id",
    "method",
    "params"
  ],
  "properties": {
    "protocol_version": {
      "const": "v1"
    },
    "kind": {
      "const": "request"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "method": {
      "type": "string",
      "enum": [
        "start_session",
        "submit_turn",
        "stream_events",
        "resolve_approval",
        "shutdown_session"
      ]
    },
    "params": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "method": {
            "const": "start_session"
          }
        },
        "required": [
          "method"
        ]
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "properties": {
              "client_name": {
                "type": "string"
              },
              "metadata": {
                "type": "object"
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "submit_turn"
          }
        },
        "required": [
          "method"
        ]
      },
      "then": {
        "required": [
          "session_id"
        ],
        "properties": {
          "params": {
            "type": "object",
            "required": [
              "input"
            ],
            "properties": {
              "input": {
                "type": "string",
                "minLength": 1
              },
              "metadata": {
                "type": "object"
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "stream_events"
          }
        },
        "required": [
          "method"
        ]
      },
      "then": {
        "required": [
          "session_id"
        ],
        "properties": {
          "params": {
            "type": "object",
            "properties": {
              "from_seq": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "resolve_approval"
          }
        },
        "required": [
          "method"
        ]
      },
      "then": {
        "required": [
          "session_id"
        ],
        "properties": {
          "params": {
            "type": "object",
            "required": [
              "turn_id",
              "request_id",
              "approved"
            ],
            "properties": {
              "turn_id": {
                "type": "string",
                "minLength": 1
              },
              "request_id": {
                "type": "string",
                "minLength": 1
              },
              "approved": {
                "type": "boolean"
              },
              "reason": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "shutdown_session"
          }
        },
        "required": [
          "method"
        ]
      },
      "then": {
        "required": [
          "session_id"
        ]
      }
    }
  ],
  "additionalProperties": false
}
