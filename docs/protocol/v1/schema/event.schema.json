{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openjax.dev/schemas/protocol/v1/event.schema.json",
  "title": "OpenJax Protocol v1 Event",
  "type": "object",
  "required": [
    "protocol_version",
    "kind",
    "session_id",
    "event_type",
    "payload"
  ],
  "properties": {
    "protocol_version": {
      "const": "v1"
    },
    "kind": {
      "const": "event"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "turn_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "turn_started",
        "tool_call_started",
        "tool_call_completed",
        "assistant_delta",
        "assistant_message",
        "approval_requested",
        "approval_resolved",
        "turn_completed",
        "session_shutdown_complete",
        "error"
      ]
    },
    "payload": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "turn_started",
              "tool_call_started",
              "tool_call_completed",
              "assistant_delta",
              "assistant_message",
              "approval_requested",
              "approval_resolved",
              "turn_completed"
            ]
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "required": [
          "turn_id"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "approval_requested"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "request_id",
              "target",
              "reason"
            ],
            "properties": {
              "request_id": {
                "type": "string",
                "minLength": 1
              },
              "target": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "approval_resolved"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "request_id",
              "approved"
            ],
            "properties": {
              "request_id": {
                "type": "string",
                "minLength": 1
              },
              "approved": {
                "type": "boolean"
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "tool_call_started"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "tool_name"
            ],
            "properties": {
              "tool_name": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "tool_call_completed"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "tool_name",
              "ok",
              "output"
            ],
            "properties": {
              "tool_name": {
                "type": "string",
                "minLength": 1
              },
              "ok": {
                "type": "boolean"
              },
              "output": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "assistant_delta"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "content_delta"
            ],
            "properties": {
              "content_delta": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "assistant_message"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "content"
            ],
            "properties": {
              "content": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
