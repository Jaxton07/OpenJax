{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openjax.dev/schemas/protocol/v1/event.schema.json",
  "title": "OpenJax Protocol v1 Event",
  "type": "object",
  "required": ["protocol_version", "kind", "session_id", "event_type", "payload"],
  "properties": {
    "protocol_version": { "const": "v1" },
    "kind": { "const": "event" },
    "session_id": { "type": "string", "minLength": 1 },
    "turn_id": { "type": "string", "minLength": 1 },
    "event_type": {
      "type": "string",
      "description": "assistant_message is deprecated compatibility-only. A keeps the bridge, B keeps the legacy fallback, and C removes it from the recommended producer surface.",
      "enum": [
        "turn_started",
        "tool_call_started",
        "tool_args_delta",
        "tool_call_progress",
        "tool_call_completed",
        "tool_call_failed",
        "response_started",
        "response_text_delta",
        "response_resumed",
        "response_completed",
        "response_error",
        "assistant_message",
        "approval_requested",
        "approval_resolved",
        "turn_completed",
        "session_shutdown_complete",
        "error"
      ]
    },
    "payload": { "type": "object" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "turn_started",
              "tool_call_started",
              "tool_args_delta",
              "tool_call_progress",
              "tool_call_completed",
              "tool_call_failed",
              "response_started",
              "response_text_delta",
              "response_resumed",
              "response_completed",
              "response_error",
              "assistant_message",
              "approval_requested",
              "approval_resolved",
              "turn_completed"
            ]
          }
        },
        "required": ["event_type"]
      },
      "then": {
        "required": ["turn_id"]
      }
    },
    {
      "if": {
        "properties": { "event_type": { "const": "response_text_delta" } },
        "required": ["event_type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["content_delta"],
            "properties": {
              "content_delta": { "type": "string" },
              "stream_source": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "event_type": { "const": "response_completed" } },
        "required": ["event_type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["content"],
            "properties": {
              "content": { "type": "string" },
              "stream_source": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "event_type": { "const": "response_error" } },
        "required": ["event_type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["code", "message", "retryable"],
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "retryable": { "type": "boolean" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "tool_call_started",
              "tool_args_delta",
              "tool_call_progress",
              "tool_call_completed",
              "tool_call_failed"
            ]
          }
        },
        "required": ["event_type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["tool_call_id", "tool_name"],
            "properties": {
              "tool_call_id": { "type": "string" },
              "tool_name": { "type": "string" }
            }
          }
        }
      }
    }
  ]
}
